{
  "name": "zfl-22-fish-rubbing-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "pretest": "node scripts/backup-data.js",
    "test": "node --test --test-reporter=spec test/*.test.js",
    "posttest": "node scripts/restore-data.js",
    "test:ci": "node --test --test-reporter=spec --test-reporter=junit --test-reporter-destination=junit.xml test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
